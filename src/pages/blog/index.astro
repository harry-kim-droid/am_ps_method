---
import Base from '../../layouts/Base.astro'; import {getCollection} from 'astro:content';
const posts=(await getCollection('blog',({data})=>data.status==='published')).sort((a,b)=>b.data.publishedAt.valueOf()-a.data.publishedAt.valueOf());
---
<Base title="Codex 코드리뷰 자동화 가이드 | 리뷰 워크벤치"><header class="page-head"><span class="eyebrow">FIELD NOTES</span><h1>혼자 만드는 개발자의<br />코드리뷰 노트</h1><p>직접 실행할 수 있는 설정과 실패하기 쉬운 지점만 기록합니다.</p></header><div class="listing post-list">{posts.map(post=><a class="post-link" href={`${import.meta.env.BASE_URL}blog/${post.id}/`}><span class="post-meta">{post.data.publishedAt.toLocaleDateString('ko-KR')} · {post.data.keywords.join(' / ')}</span><h2>{post.data.title}</h2><p>{post.data.description}</p></a>)}</div></Base>
