---
import Base from '../../layouts/Base.astro'; import {getCollection,render} from 'astro:content'; import {site} from '../../config';
export async function getStaticPaths(){const posts=await getCollection('blog',({data})=>data.status==='published');return posts.map(post=>({params:{id:post.id},props:{post}}));}
const {post}=Astro.props; const {Content}=await render(post);
---
<Base title={`${post.data.title} | ${site.name}`} description={post.data.description} type="article"><article><header class="page-head"><span class="eyebrow">{post.data.keywords.join(' / ')}</span><h1>{post.data.title}</h1><p>{post.data.description}</p><div class="post-meta">발행 {post.data.publishedAt.toLocaleDateString('ko-KR')}{post.data.updatedAt&&` · 수정 ${post.data.updatedAt.toLocaleDateString('ko-KR')}`}</div></header><div class="prose"><Content/><aside class="cta-box"><strong>{post.data.cta==='sample'?'먼저 무료 프롬프트로 결과를 확인하세요.':'설정 시간을 줄이고 바로 테스트하세요.'}</strong><p>{post.data.cta==='sample'?'실제 키트와 같은 원칙으로 만든 PR 리뷰 프롬프트와 설치 전 체크리스트입니다.':'워크플로, 프롬프트, 설치·비용·보안 가이드를 한 번에 제공합니다.'}</p><a class="button" href={post.data.cta==='sample'?`${import.meta.env.BASE_URL}sample/`:`${import.meta.env.BASE_URL}product/`}>{post.data.cta==='sample'?'무료 샘플 보기':'자동화 키트 보기'}</a></aside></div></article></Base>
